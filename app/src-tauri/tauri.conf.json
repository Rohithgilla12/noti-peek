{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noti-peek",
  "version": "0.2.2",
  "identifier": "dev.notipeek.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "noti-peek",
        "width": 1120,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "focus": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 }
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: blob:; img-src 'self' data: https: blob:; connect-src 'self' ipc: http://ipc.localhost https://api.notipeek.dev https://*.workers.dev http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;",
      "devCsp": "default-src 'self' tauri: asset: blob:; img-src 'self' data: https: blob:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https://api.notipeek.dev https://*.workers.dev; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/Rohithgilla12/noti-peek-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCQThDNDFBOTRDNTM5RTMKUldUak9jV1VHc1NvTytnNVhEVnp2TFVzcXQ0SXF2NlFDK0lkemV0dDlQRjJvejF4UnJlRTFhalUK"
    }
  }
}

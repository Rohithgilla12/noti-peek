{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noti-peek",
  "version": "0.1.0",
  "identifier": "dev.notipeek.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "noti-peek",
        "width": 400,
        "height": 600,
        "resizable": true,
        "minWidth": 350,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {},
    "http": {
      "scope": {
        "allow": [
          { "url": "http://localhost:*/**" },
          { "url": "https://api.notipeek.dev/**" },
          { "url": "https://*.workers.dev/**" }
        ]
      }
    },
    "store": {}
  }
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "updater:default",
    "notification:default",
    "process:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/**" },
        { "url": "https://api.notipeek.dev/**" },
        { "url": "https://*.workers.dev/**" }
      ]
    }
  ]
}
